{
  "dataset_type": "clinc150",
  "dataset_name": "clinc150",
  "dataset_source": "../data/clinc150/data_full.json",
  "train_split": "train",
  "validation_split": "val",
  "test_split": "test",
  "include_oos": true,
  "artifacts_dir": "../artifacts/clinc150/tfidf_svc_random_search",
  "reports_dir": "../reports/clinc150/tfidf_svc_random_search",
  "text_column": "text",
  "label_column": "label",
  "random_seed": 42,
  "tfidf": {
    "lowercase": true,
    "strip_accents": "unicode",
    "normalization": "lemma",
    "ngram_range": [1, 2],
    "min_df": 2,
    "max_df": 0.98,
    "sublinear_tf": true,
    "max_features": 50000
  },
  "classifier": {
    "c": 1.0,
    "class_weight": "balanced",
    "max_iter": 5000,
    "dual": true,
    "random_state": 42
  },
  "analysis": {
    "top_k_confusions": 25,
    "top_k_features_per_class": 20
  },
  "search": {
    "search_type": "randomized",
    "n_iter": 20,
    "cv": 5,
    "scoring": "f1_macro",
    "n_jobs": null,
    "verbose": 1,
    "refit": true,
    "random_state": 42,
    "param_distributions": {
      "vectorizer__ngram_range": [[1, 2], [1, 3]],
      "vectorizer__min_df": [1, 2, 3],
      "vectorizer__max_df": [0.95, 0.98, 1.0],
      "vectorizer__sublinear_tf": [true, false],
      "classifier__C": [0.1, 1.0, 10.0]
    }
  }
}
